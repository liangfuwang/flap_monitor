# Telegram API 配置
TG_API_ID=your_api_id
TG_API_HASH=your_api_hash
TG_PHONE_NUMBER=+86xxxxxxxxxxx

# 告警目标群组
TG_TARGET_GROUP=-1003676613114

# BSC RPC（可选，默认使用公共 RPC）
BSC_RPC_URL=https://bsc-dataseed.binance.org/
BSC_RPC_ANKR=https://rpc.ankr.com/bsc/your_ankr_api_key
BSC_RPC_NODEREAL=https://bsc-mainnet.nodereal.io/v1/your_nodereal_key

# 轮询间隔（秒），默认 30 秒
POLL_INTERVAL=30

# 要监控的代币地址列表（逗号分隔）
# 留空则监控 board 上通过 VaultPortal 创建的所有新代币
WATCH_TOKENS=0xf530b66746898ca3b5cf3bb97ad962a6970e7777
